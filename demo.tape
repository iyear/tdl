Output tdl_tui_demo.gif

Set FontSize 16
Set Width 1200
Set Height 800

Hide
Type ".\tdl.exe tui"
Enter
Sleep 2s
Show

# Navigate to Browser Tab
Sleep 2s
Type "b"
Sleep 2s

# Navigate to Downloads Tab
Type "l"
Sleep 2s

# Navigate to Forwarding Tab
Type "w"
Sleep 2s

# Return to Dashboard
Type "d"
Sleep 2s

# Open Settings
Type "c"
Sleep 2s
Type "j"
Sleep 1s
Type "j"
Sleep 2s
Escape

Sleep 2s
Type "q"
